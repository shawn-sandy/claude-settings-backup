  "model": "opusplan",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); if echo \"$INPUT\" | jq -r '.tool_input.command' 2>/dev/null | grep -q 'git commit'; then BRANCH=$(git branch --show-current 2>/dev/null); if [ \"$BRANCH\" = 'main' ] || [ \"$BRANCH\" = 'primary' ] || [ \"$BRANCH\" = 'master' ]; then echo \"WARNING: You are on the $BRANCH branch. Switch to a feature branch before committing.\" >&2; exit 1; fi; UNSTAGED=$(git diff --name-only 2>/dev/null | wc -l | tr -d ' '); UNTRACKED=$(git ls-files --others --exclude-standard 2>/dev/null | wc -l | tr -d ' '); if [ \"$UNSTAGED\" -gt 0 ] || [ \"$UNTRACKED\" -gt 0 ]; then echo \"Note: $UNSTAGED unstaged changes, $UNTRACKED untracked files. Stage specific files rather than using git add -A.\"; fi; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "INPUT=$(cat); if echo \"$INPUT\" | jq -r '.tool_input.command' 2>/dev/null | grep -q 'npm publish'; then BRANCH=$(git branch --show-current 2>/dev/null); if [ \"$BRANCH\" = 'main' ] || [ \"$BRANCH\" = 'primary' ] || [ \"$BRANCH\" = 'master' ]; then echo \"WARNING: Do not publish from the $BRANCH branch. Use a release branch.\" >&2; exit 1; fi; NPM_USER=$(npm whoami 2>&1); if echo \"$NPM_USER\" | grep -qi 'error\\|unauthorized\\|ENEEDAUTH'; then echo \"ERROR: npm auth failed ($NPM_USER). Run npm login first.\" >&2; exit 1; fi; echo \"npm auth OK as $NPM_USER, branch OK.\"; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/scripts/settings-backup.sh >> $HOME/.claude/logs/settings-backup.log 2>&1",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path' 2>/dev/null); [ -n \"$FILE\" ] && [ \"$FILE\" != 'null' ] && prettier --write --ignore-unknown \"$FILE\" 2>/dev/null; true",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/validate-plan-filename.py",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); dir=$(basename \"$(echo \"$input\" | jq -r '.workspace.current_dir')\"); model=$(echo \"$input\" | jq -r '.model.display_name'); used=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); ctx=\"\"; if [ -n \"$used\" ]; then pct=$(printf '%.0f' \"$used\"); filled=$(( pct * 10 / 100 )); empty=$(( 10 - filled )); bar=\"\"; i=0; while [ $i -lt $filled ]; do bar=\"${bar}█\"; i=$(( i + 1 )); done; i=0; while [ $i -lt $empty ]; do bar=\"${bar}░\"; i=$(( i + 1 )); done; ctx=\" | [${bar}] ${pct}%\"; fi; printf '\\033[2m%s | %s%s\\033[0m' \"$dir\" \"$model\" \"$ctx\""
  },
